ed.xlsx')"]},{"cell_type":"code","source":["#AFS (Bahrain Region) - Merge with onboarding dates\n","# --- Upload both files in Colab ---\n","files.upload()\n","\n","# Load merged transactions and onboarding dates\n","merged = pd.read_excel('AFS_merged.xlsx', dtype=str)\n","onb = pd.read_csv('afs_onboarding_dates.csv', dtype=str)\n","\n","# Parse the onboarding date (format: 16-NOV-18)\n","onb['OnboardingDate'] = pd.to_datetime(onb['MMM_INSD_SYDT'], format='%d-%b-%y', errors='coerce')\n","\n","# Rename the code column to match, keep only what we need\n","onb = onb.rename(columns={'MMM_MER_CODE': 'MID'})[['MID', 'OnboardingDate']]\n","\n","# (safety) one row per MID — no dups here, but guard anyway\n","onb = onb.drop_duplicates(subset='MID', keep='first')\n","\n","# Join onto the merged file by MID\n","result = merged.merge(onb, on='MID', how='left')\n","\n","# Report\n","print('Rows:', len(result), '(should equal', len(merged), ')')\n","matched = result['OnboardingDate'].notna().sum()\n","print(f'Rows with onboarding date: {matched:,} ({matched/len(result)*100:.1f}%)')\n","print('Onboarding date range:', result['OnboardingDate'].min(), 'to', result['OnboardingDate'].max())\n","\n","# Save\n","result.to_excel('AFS_merchants_dataset.xlsx', index=False)\n","# from google.colab import files\n","files.download('AFS_merchants_dataset.xlsx')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":158},"executionInfo":{"status":"ok","timestamp":1783707496600,"user_tz":-180,"elapsed":263651,"user":{"displayName":"Maram Alkhunaizi","userId":"12033410406203434863"}},"outputId":"4447bab2-75be-4be2-daa7-9b73509998c8","id":"xLr9aSjzLJAx"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<IPython.core.display.HTML object>"],"text/html":["\n","     <input type=\"file\" id=\"files-95abfeb1-0ad4-4324-a9fc-4c0cfa8e787f\" name=\"files[]\" multiple disabled\n","        style=\"border:none\" />\n","     <output id=\"result-95abfeb1-0ad4-4